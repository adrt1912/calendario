            <Button fx:id="botonBorrar" mnemonicParsing="false" onAction="#borrarTodo" prefHeight="35.0" prefWidth="180.0" style="-fx-background-color: #ff4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="%configuracionMenuPrincipal.borrarContenido">

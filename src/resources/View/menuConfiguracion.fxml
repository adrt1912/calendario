<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ConfiguracionController">
   <children>
      <VBox alignment="TOP_CENTER" layoutX="-1.0" prefHeight="428.0" prefWidth="600.0" spacing="20.0">

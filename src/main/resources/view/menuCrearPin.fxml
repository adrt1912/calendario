<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="360.0" prefWidth="420.0" style="-fx-background-color: -fx-base;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MenuCrearPINController">
   <children>
      <VBox alignment="TOP_CENTER" spacing="15.0" >
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: -fx-text-base;" text="%establecerPin.Titulo">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Text>
               </children>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: -fx-text-base;" text="%loginPin.Usuario">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Text>
                  <TextField fx:id="campoNuevoUsuario" prefHeight="32.0" promptText="Ej: aday_linux" style="-fx-background-radius: 6px; -fx-border-radius: 6px;" />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: -fx-text-base;" text="%establecerPin.Contraseña">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Text>
                  <PasswordField fx:id="campoContrasenia" prefHeight="32.0" promptText="••••" style="-fx-background-radius: 6px; -fx-border-radius: 6px;" />
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: -fx-text-base;" text="%establecerPin.Confirmar">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Text>
                  <PasswordField fx:id="campoConfirmarContrasenia" prefHeight="32.0" promptText="••••" style="-fx-background-radius: 6px; -fx-border-radius: 6px;" />
               </children>
            </VBox>

            <Text fx:id="textoError" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-fill: #ff4444;" textAlignment="CENTER" wrappingWidth="360.0">
               <font>
                  <Font size="12.0" />
               </font>
            </Text>

            <HBox alignment="CENTER_RIGHT" spacing="12.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="botonCancelar" mnemonicParsing="false" onAction="#cancelar" prefHeight="32.0" prefWidth="95.0" style="-fx-background-color: transparent; -fx-border-color: #888888; -fx-border-radius: 6px; -fx-text-fill: -fx-text-base; -fx-cursor: hand;" text="%boton.Cancelar" />
                  <Button mnemonicParsing="false" onAction="#guardarPIN" prefHeight="32.0" prefWidth="95.0" style="-fx-background-color: #0078D7; -fx-background-radius: 6px; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="%boton.Guardar" />
               </children>
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>